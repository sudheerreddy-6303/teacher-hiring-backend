# ═══════════════════════════════════════════════════════════════════════════
# AcadHr BACKEND — copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════════

# Server (Railway sets PORT automatically — do not hardcode on Railway)
PORT=5000
NODE_ENV=development

# ── MySQL LOCAL (XAMPP/WAMP) ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=acadhr

# ── MySQL RAILWAY (copy from Railway → MySQL service → Variables / Connect) ─
# Do NOT use placeholder text like "your-mysql-host" — copy real values from dashboard.
# Example public proxy (yours will differ):
# DB_HOST=tramway.proxy.rlwy.net
# DB_PORT=53767
# DB_USER=root
# DB_PASSWORD=<from Railway MySQL>
# DB_NAME=railway
#
# Or link MySQL to backend in Railway and use variable references:
# MYSQLHOST, MYSQLPORT, MYSQLUSER, MYSQLPASSWORD, MYSQLDATABASE

# Set true only if your host requires SSL (some cloud DBs)
DB_SSL=false

# ── JWT (use a long random string in production) ───────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES=7d

# ── Email — Gmail App Password (optional for local dev) ───────────────────
# Without EMAIL_USER + EMAIL_PASS, OTP codes print in the server console.
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-character-gmail-app-password
EMAIL_FROM=AcadHr <your-email@gmail.com>

# ── Optional (not required by current code) ───────────────────────────────
# FRONTEND_URL=http://localhost:3000
