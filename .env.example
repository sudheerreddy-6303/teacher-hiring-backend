# ─── AcadHr Backend — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git — only commit this .env.example file.

PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=123456
DB_NAME=acadhr

JWT_SECRET=generate_with__node_-e_console.log_require_crypto_randomBytes_64_toString_hex
JWT_EXPIRY=7d

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16char_app_password
EMAIL_FROM="AcadHr <your_gmail@gmail.com>"

OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5

COMPANY_NAME=AcadHr
COMPANY_TAGLINE=India's Premier Teacher Hiring Platform
COMPANY_COLOR=#1A56DB
COMPANY_FOOTER=© 2025 AcadHr · Made with ❤️ in Hyderabad, India
