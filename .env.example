# AcadHr Frontend Environment Variables
#
# Local dev: copy to .env and set your local backend URL.
#   REACT_APP_API_URL=http://localhost:5000/api
#
# Production (Render) uses .env.production which is committed:
#   Frontend: https://teacher-hiring-frontend.onrender.com
#   Backend:  https://teacher-hiring-backend.onrender.com
REACT_APP_API_URL=http://localhost:5000/api
