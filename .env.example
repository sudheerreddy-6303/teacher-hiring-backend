PORT=5000
NODE_ENV=production

# MySQL (from Railway MySQL plugin)
DB_HOST=your-mysql-host.railway.internal
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-password
DB_NAME=acadhr

# JWT
JWT_SECRET=generate-with-node-crypto-randomBytes-64-hex
JWT_EXPIRY=7d

# Email (Gmail App Password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-char-app-password
EMAIL_FROM=AcadHr <your-email@gmail.com>

# OTP
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5

# CORS - set to your Vercel/Netlify frontend URL
ALLOWED_ORIGINS=https://your-frontend.vercel.app

# Company
COMPANY_NAME=AcadHr
COMPANY_TAGLINE=India's Premier Teacher Hiring Platform
COMPANY_COLOR=#1A56DB
COMPANY_FOOTER=© 2025 AcadHr · Made with ❤️ in Hyderabad, India
